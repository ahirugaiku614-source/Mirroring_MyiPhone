<Window x:Class="Mirroring_iPhone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mirroring_iPhone"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="iPhone Mirroring App" Height="700" Width="450"
        Background="#1E1E1E">
    <Grid>
        <!-- WindowsFormsHostを削除し、VLCのビデオ表示領域を配置 -->
        <vlc:VideoView x:Name="VlcPlayer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Grid>
</Window>
